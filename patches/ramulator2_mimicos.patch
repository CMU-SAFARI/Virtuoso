+# Ramulator2 MimicOS Pintool Makefile
+#
+# Build:
+#   SDE_BUILD_KIT=/path/to/sde_kit make
+#
+# The SDE_BUILD_KIT should point to the same SDE kit used by Sniper.
+
+ifdef SDE_BUILD_KIT
+
+PIN_ROOT := $(SDE_BUILD_KIT)/pinkit
+SDE_ROOT := $(PIN_ROOT)/sde-example
+PINPLAY_ROOT := $(PIN_ROOT)/pinplay
+CONFIG_ROOT := $(PIN_ROOT)/source/tools/Config
+
+ifneq (,$(wildcard $(CONFIG_ROOT)/makefile.config))
+include $(CONFIG_ROOT)/makefile.config
+include makefile.rules
+include $(TOOLS_ROOT)/Config/makefile.default.rules
+else
+$(warning "Cannot find PIN config at $(CONFIG_ROOT)")
+all:
+clean:
+endif
+
+else
+$(error "SDE_BUILD_KIT must be set. Point it to the SDE kit directory (e.g., snipersim/sde_kit)")
+endif
