diff --git a/pintool/ramulator_ipc.h b/pintool/ramulator_ipc.h
new file mode 100644
index 0000000..b17a2f2
--- /dev/null
+++ b/pintool/ramulator_ipc.h
@@ -0,0 +1,72 @@
+/**
+ * @file ramulator_ipc.h
+ * @brief IPC protocol between Ramulator2 and the MimicOS SDE pintool.
+ *
+ * Binary message protocol over Unix pipes (or named FIFOs).
+ * All multi-byte values are little-endian (native x86).
+ */
+
+#ifndef RAMULATOR_IPC_H
+#define RAMULATOR_IPC_H
+
+#include <cstdint>
+#include <vector>
+
+namespace RamulatorIPC {
+
+// Message types
+enum MsgType : uint8_t {
+  // Ramulator2 → Pintool
+  PAGE_FAULT_REQUEST = 1,   // Page fault occurred, MimicOS should handle it
+  SIMULATION_END     = 10,  // Simulation is ending, pintool should terminate
+
+  // Pintool → Ramulator2
+  FAULT_RESPONSE     = 2,   // MimicOS resolved the page fault
+  MEMORY_ACCESS      = 3,   // MimicOS memory access during fault handling
+  MIMICOS_READY      = 4,   // MimicOS is initialized and ready
+  MIMICOS_DONE       = 5,   // MimicOS finished processing (no more accesses)
+};
+
+// Ramulator2 → Pintool: page fault request
+struct FaultRequest {
+  uint64_t vpn;
+  uint32_t num_frames_needed;
+  uint32_t core_id;
+};
+
+// Pintool → Ramulator2: page fault response
+struct FaultResponse {
+  uint64_t ppn;                    // Allocated physical page number
+  uint32_t page_size_log2;         // 12=4KB, 21=2MB
+  uint32_t num_frames;             // Number of PT frames
+  // Followed by num_frames × uint64_t frame PPNs
+};
+
+// Pintool → Ramulator2: MimicOS memory access
+struct MemoryAccess {
+  uint64_t addr;        // Physical address accessed by MimicOS
+  uint8_t  is_write;    // 0=read, 1=write
+};
+
+// Helper: write a message to a file descriptor
+static inline bool write_msg(int fd, MsgType type, const void* data, size_t len) {
+  uint8_t t = static_cast<uint8_t>(type);
+  if (write(fd, &t, 1) != 1) return false;
+  if (len > 0 && write(fd, data, len) != static_cast<ssize_t>(len)) return false;
+  return true;
+}
+
+// Helper: read exactly N bytes from a file descriptor
+static inline bool read_exact(int fd, void* buf, size_t len) {
+  size_t total = 0;
+  while (total < len) {
+    ssize_t n = read(fd, static_cast<char*>(buf) + total, len - total);
+    if (n <= 0) return false;
+    total += n;
+  }
+  return true;
+}
+
+}  // namespace RamulatorIPC
+
+#endif  // RAMULATOR_IPC_H
diff --git a/pintool/ramulator_recorder.cpp b/pintool/ramulator_recorder.cpp
new file mode 100644
index 0000000..588f56b
--- /dev/null
+++ b/pintool/ramulator_recorder.cpp
@@ -0,0 +1,350 @@
+/**
+ * @file ramulator_recorder.cpp
+ * @brief SDE pintool for MimicOS ↔ Ramulator2 integration.
+ *
+ * This tool instruments MimicOS running under SDE and:
+ *   1. Intercepts magic instructions (xchg bx,bx) for MimicOS IPC
+ *   2. Records memory accesses during page fault handling
+ *   3. Communicates with Ramulator2 via file descriptors (pipes)
+ *
+ * Usage:
+ *   sde64 -t64 ramulator_recorder.so \
+ *     -ramulator:ipc_read_fd 3 -ramulator:ipc_write_fd 4 \
+ *     -ramulator:roi 1 \
+ *     -- mimicos/build/startup_mimicos <config> <trace> <output>
+ */
+
+#include <iostream>
+#include <fstream>
+#include <cstring>
+#include <unordered_set>
+#include <cstdlib>
+#include <unistd.h>
+#include <sys/types.h>
+
+#include "pin.H"
+
+#if defined(SDE_INIT)
+#include "sde-init.H"
+#include "sde-control.H"
+#endif
+
+#ifdef PINPLAY
+#include "pinplay.H"
+#endif
+
+#include "ramulator_ipc.h"
+
+// ============================================================================
+// Sim API command codes (must match sim_api.h used by MimicOS)
+// ============================================================================
+#define SIM_CMD_ROI_START        1
+#define SIM_CMD_ROI_END          2
+#define SIM_CMD_MALLOC           100
+#define SIM_CMD_START_PROCESS    101
+#define SIM_CMD_MIMICOS_RESULT   102
+#define SIM_CMD_CONTEXT_SWITCH   103
+#define SIM_CMD_RECEIVE_MESSAGE  104
+
+// ============================================================================
+// Knobs
+// ============================================================================
+KNOB<INT64> KnobIpcReadFd(KNOB_MODE_WRITEONCE, "pintool", "ramulator:ipc_read_fd", "0",
+                          "File descriptor to read IPC from Ramulator2");
+KNOB<INT64> KnobIpcWriteFd(KNOB_MODE_WRITEONCE, "pintool", "ramulator:ipc_write_fd", "1",
+                           "File descriptor to write IPC to Ramulator2");
+KNOB<UINT64> KnobUseROI(KNOB_MODE_WRITEONCE, "pintool", "ramulator:roi", "0",
+                        "Use ROI markers");
+KNOB<BOOL> KnobVerbose(KNOB_MODE_WRITEONCE, "pintool", "ramulator:verbose", "0",
+                       "Verbose output");
+
+// ============================================================================
+// Global state
+// ============================================================================
+static int g_ipc_read_fd = 0;
+static int g_ipc_write_fd = 1;
+static bool g_in_roi = false;
+static bool g_in_fault_handling = false;  // True between context switches
+static bool g_verbose = false;
+
+// Pending fault request from Ramulator2
+static RamulatorIPC::FaultRequest g_pending_fault;
+static bool g_has_pending_fault = false;
+
+// MimicOS result buffer
+static uint64_t g_result_argv[64];
+static int g_result_argc = 0;
+
+// Memory access tracking during fault handling
+static uint64_t g_fault_mem_accesses = 0;
+// Track unique cache lines accessed during fault handling (deduplicate)
+static std::unordered_set<uint64_t> g_fault_cachelines;
+static const uint64_t CACHELINE_MASK = ~63ULL;  // 64-byte cache lines
+
+// ============================================================================
+// IPC helpers
+// ============================================================================
+static void send_to_ramulator(RamulatorIPC::MsgType type, const void* data, size_t len) {
+  uint8_t t = static_cast<uint8_t>(type);
+  write(g_ipc_write_fd, &t, 1);
+  if (len > 0) write(g_ipc_write_fd, data, len);
+}
+
+static bool recv_from_ramulator(void* buf, size_t len) {
+  return RamulatorIPC::read_exact(g_ipc_read_fd, buf, len);
+}
+
+// ============================================================================
+// Magic instruction handler
+// ============================================================================
+ADDRINT handleMagic(THREADID threadid, const CONTEXT* ctxt,
+                    ADDRINT gax, ADDRINT gbx, ADDRINT gcx)
+{
+  uint64_t cmd = gax;
+  uint64_t arg0 = gbx;
+  uint64_t arg1 = gcx;
+
+  if (g_verbose) {
+    std::cerr << "[RAMULATOR_RECORDER] Magic cmd=" << cmd
+              << " arg0=0x" << std::hex << arg0 << std::dec
+              << " arg1=0x" << std::hex << arg1 << std::dec << std::endl;
+  }
+
+  switch (cmd) {
+    case SIM_CMD_ROI_START:
+      g_in_roi = true;
+      if (g_verbose) std::cerr << "[RAMULATOR_RECORDER] ROI START" << std::endl;
+      break;
+
+    case SIM_CMD_ROI_END:
+      g_in_roi = false;
+      if (g_verbose) std::cerr << "[RAMULATOR_RECORDER] ROI END" << std::endl;
+      break;
+
+    case SIM_CMD_START_PROCESS: {
+      // MimicOS is starting the application trace
+      // arg0 = pointer to trace file path (in MimicOS address space)
+      char path[256];
+      PIN_SafeCopy(path, reinterpret_cast<void*>(arg0), 255);
+      path[255] = '\0';
+      if (g_verbose) {
+        std::cerr << "[RAMULATOR_RECORDER] START_PROCESS: " << path << std::endl;
+      }
+      // Signal Ramulator2 that MimicOS is ready
+      send_to_ramulator(RamulatorIPC::MIMICOS_READY, path, strlen(path) + 1);
+      break;
+    }
+
+    case SIM_CMD_CONTEXT_SWITCH: {
+      // MimicOS is yielding — either finishing fault handling or waiting for next fault
+      if (g_in_fault_handling) {
+        // Finished handling fault — send DONE marker
+        g_in_fault_handling = false;
+        send_to_ramulator(RamulatorIPC::MIMICOS_DONE, nullptr, 0);
+        if (g_verbose) {
+          std::cerr << "[RAMULATOR_RECORDER] Context switch: fault handling done ("
+                    << g_fault_mem_accesses << " mem accesses)" << std::endl;
+        }
+        // Fall through to read the next fault (MimicOS loops back to SimReceiveMessage)
+      }
+
+      // Block until Ramulator2 sends a fault request (or end signal)
+      uint8_t msg_type;
+      if (!recv_from_ramulator(&msg_type, 1)) {
+        if (g_verbose) std::cerr << "[RAMULATOR_RECORDER] IPC pipe closed, exiting" << std::endl;
+        PIN_ExitApplication(0);
+        return 0;
+      }
+
+      if (msg_type == RamulatorIPC::PAGE_FAULT_REQUEST) {
+        recv_from_ramulator(&g_pending_fault, sizeof(g_pending_fault));
+        g_has_pending_fault = true;
+        g_in_fault_handling = true;
+        g_fault_mem_accesses = 0;
+        g_fault_cachelines.clear();
+        if (g_verbose) {
+          std::cerr << "[RAMULATOR_RECORDER] Received fault: vpn=0x"
+                    << std::hex << g_pending_fault.vpn << std::dec
+                    << " frames=" << g_pending_fault.num_frames_needed << std::endl;
+        }
+      } else if (msg_type == RamulatorIPC::SIMULATION_END) {
+        if (g_verbose) std::cerr << "[RAMULATOR_RECORDER] Simulation end received" << std::endl;
+        PIN_ExitApplication(0);
+        return 0;
+      }
+
+      return 42;
+    }
+
+    case SIM_CMD_RECEIVE_MESSAGE: {
+      // MimicOS wants to read the fault message
+      // arg0 = pointer to argc (int*)
+      // arg1 = pointer to argv (uint64_t*)
+      if (g_has_pending_fault) {
+        // Build the message: [exception_type=1, va, num_frames]
+        int argc = 3;
+        uint64_t argv[3];
+        argv[0] = 1;  // PAGE_FAULT exception type
+        argv[1] = g_pending_fault.vpn << 12;  // Virtual address
+        argv[2] = g_pending_fault.num_frames_needed;
+
+        // Write to MimicOS memory
+        PIN_SafeCopy(reinterpret_cast<void*>(arg0), &argc, sizeof(int));
+        PIN_SafeCopy(reinterpret_cast<void*>(arg1), argv, argc * sizeof(uint64_t));
+        g_has_pending_fault = false;
+      }
+      break;
+    }
+
+    case SIM_CMD_MIMICOS_RESULT: {
+      // MimicOS is sending back the allocation result
+      // arg0 = argc (int)
+      // arg1 = pointer to argv (uint64_t*)
+      g_result_argc = static_cast<int>(arg0);
+      if (g_result_argc > 0 && g_result_argc < 64) {
+        PIN_SafeCopy(g_result_argv, reinterpret_cast<void*>(arg1),
+                     g_result_argc * sizeof(uint64_t));
+      }
+
+      // Parse: argv[0]=exception_type, argv[1]=vpn, argv[2]=ppn,
+      //        argv[3]=page_size, argv[4..]=frames
+      if (g_result_argc >= 4) {
+        RamulatorIPC::FaultResponse resp;
+        resp.ppn = g_result_argv[2];
+        resp.page_size_log2 = static_cast<uint32_t>(g_result_argv[3]);
+        resp.num_frames = (g_result_argc > 4) ? (g_result_argc - 4) : 0;
+
+        // Send response header
+        send_to_ramulator(RamulatorIPC::FAULT_RESPONSE, &resp, sizeof(resp));
+        // Send frame PPNs
+        if (resp.num_frames > 0) {
+          write(g_ipc_write_fd, &g_result_argv[4], resp.num_frames * sizeof(uint64_t));
+        }
+
+        if (g_verbose) {
+          std::cerr << "[RAMULATOR_RECORDER] Result: ppn=" << resp.ppn
+                    << " page_size=" << resp.page_size_log2
+                    << " frames=" << resp.num_frames << std::endl;
+        }
+      }
+      break;
+    }
+
+    case SIM_CMD_MALLOC:
+      // Ignore malloc tracking for now
+      break;
+
+    default:
+      if (g_verbose) {
+        std::cerr << "[RAMULATOR_RECORDER] Unknown magic cmd=" << cmd << std::endl;
+      }
+      break;
+  }
+
+  return gax;
+}
+
+// ============================================================================
+// Memory access recording (only during fault handling)
+// ============================================================================
+VOID handleMemory(THREADID threadid, ADDRINT addr, UINT32 size, BOOL is_write)
+{
+  if (!g_in_fault_handling) return;
+
+  // Deduplicate by cache line — only send unique cache line accesses
+  uint64_t cl_addr = static_cast<uint64_t>(addr) & CACHELINE_MASK;
+  if (g_fault_cachelines.count(cl_addr)) return;
+  g_fault_cachelines.insert(cl_addr);
+
+  RamulatorIPC::MemoryAccess ma;
+  ma.addr = cl_addr;
+  ma.is_write = is_write ? 1 : 0;
+  send_to_ramulator(RamulatorIPC::MEMORY_ACCESS, &ma, sizeof(ma));
+  g_fault_mem_accesses++;
+}
+
+// ============================================================================
+// Instrumentation callbacks
+// ============================================================================
+VOID traceCallback(TRACE trace, VOID* v)
+{
+  for (BBL bbl = TRACE_BblHead(trace); BBL_Valid(bbl); bbl = BBL_Next(bbl)) {
+    for (INS ins = BBL_InsHead(bbl); INS_Valid(ins); ins = INS_Next(ins)) {
+
+      // Detect magic instruction: xchg bx, bx
+      if (INS_IsXchg(ins) &&
+          INS_OperandReg(ins, 0) == REG_BX &&
+          INS_OperandReg(ins, 1) == REG_BX) {
+        INS_InsertPredicatedCall(
+          ins, IPOINT_BEFORE, (AFUNPTR)handleMagic,
+          IARG_RETURN_REGS, REG_GAX,
+          IARG_THREAD_ID,
+          IARG_CONST_CONTEXT,
+          IARG_REG_VALUE, REG_GAX,
+          IARG_REG_VALUE, REG_GBX,
+          IARG_REG_VALUE, REG_GCX,
+          IARG_END);
+      }
+
+      // Record memory accesses (only active during fault handling)
+      for (UINT32 i = 0; i < INS_MemoryOperandCount(ins); i++) {
+        if (INS_MemoryOperandIsRead(ins, i)) {
+          INS_InsertPredicatedCall(
+            ins, IPOINT_BEFORE, (AFUNPTR)handleMemory,
+            IARG_THREAD_ID,
+            IARG_MEMORYOP_EA, i,
+            IARG_MEMORYOP_SIZE, i,
+            IARG_BOOL, FALSE,
+            IARG_END);
+        }
+        if (INS_MemoryOperandIsWritten(ins, i)) {
+          INS_InsertPredicatedCall(
+            ins, IPOINT_BEFORE, (AFUNPTR)handleMemory,
+            IARG_THREAD_ID,
+            IARG_MEMORYOP_EA, i,
+            IARG_MEMORYOP_SIZE, i,
+            IARG_BOOL, TRUE,
+            IARG_END);
+        }
+      }
+    }
+  }
+}
+
+VOID Fini(INT32 code, VOID* v)
+{
+  if (g_verbose) {
+    std::cerr << "[RAMULATOR_RECORDER] Finished with code " << code << std::endl;
+  }
+}
+
+// ============================================================================
+// Entry point
+// ============================================================================
+int main(int argc, char* argv[])
+{
+#if defined(SDE_INIT)
+  sde_pin_init(argc, argv);
+  sde_init();
+#else
+  if (PIN_Init(argc, argv)) {
+    std::cerr << "Usage: sde64 -t64 ramulator_recorder.so [options] -- <app>" << std::endl;
+    return 1;
+  }
+#endif
+
+  g_ipc_read_fd = static_cast<int>(KnobIpcReadFd.Value());
+  g_ipc_write_fd = static_cast<int>(KnobIpcWriteFd.Value());
+  g_verbose = KnobVerbose.Value();
+
+  if (g_verbose) {
+    std::cerr << "[RAMULATOR_RECORDER] ipc_read_fd=" << g_ipc_read_fd
+              << " ipc_write_fd=" << g_ipc_write_fd << std::endl;
+  }
+
+  TRACE_AddInstrumentFunction(traceCallback, 0);
+  PIN_AddFiniFunction(Fini, 0);
+
+  PIN_StartProgram();  // Never returns
+  return 0;
+}
