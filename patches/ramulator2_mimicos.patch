diff --git a/testing/gen_trace.py b/testing/gen_trace.py
new file mode 100644
index 0000000..25d16fc
--- /dev/null
+++ b/testing/gen_trace.py
@@ -0,0 +1,90 @@
+#!/usr/bin/env python3
+"""
+Generate synthetic SimpleO3 traces with controllable properties.
+
+Format: <bubble_count> <load_addr> [writeback_addr]
+  bubble_count = number of non-memory instructions before this memory op
+  load_addr    = virtual address of load (cache-line aligned, 64B)
+  writeback_addr = optional writeback address (for stores)
+
+Usage:
+  python3 gen_trace.py --num-accesses 100000 --num-pages 64 --output trace.trace
+  python3 gen_trace.py --num-accesses 100000 --num-pages 1024 --pattern zipf --output trace.trace
+"""
+
+import argparse
+import random
+import sys
+import os
+import math
+
+
+def generate_trace(num_accesses, num_pages, pattern, bubble_mean, page_size, seed, write_ratio):
+    rng = random.Random(seed)
+    page_shift = int(math.log2(page_size))
+    cacheline_size = 64
+    lines_per_page = page_size // cacheline_size
+
+    # Generate page access sequence based on pattern
+    if pattern == "sequential":
+        pages = [i % num_pages for i in range(num_accesses)]
+    elif pattern == "random":
+        pages = [rng.randint(0, num_pages - 1) for _ in range(num_accesses)]
+    elif pattern == "zipf":
+        # Zipf distribution: few hot pages, long tail of cold pages
+        alpha = 1.2
+        weights = [1.0 / ((i + 1) ** alpha) for i in range(num_pages)]
+        total = sum(weights)
+        weights = [w / total for w in weights]
+        pages = rng.choices(range(num_pages), weights=weights, k=num_accesses)
+    elif pattern == "strided":
+        stride = max(1, num_pages // 16)
+        pages = [(i * stride) % num_pages for i in range(num_accesses)]
+    else:
+        raise ValueError(f"Unknown pattern: {pattern}")
+
+    lines = []
+    for i, page_id in enumerate(pages):
+        bubble = max(0, int(rng.gauss(bubble_mean, bubble_mean / 4)))
+        # Random cache line within the page
+        cl_offset = rng.randint(0, lines_per_page - 1)
+        vaddr = (page_id << page_shift) + cl_offset * cacheline_size
+        # Add base offset to avoid address 0
+        vaddr += 0x10000000
+
+        if rng.random() < write_ratio:
+            # Write (has writeback addr)
+            lines.append(f"{bubble} {vaddr} {vaddr}")
+        else:
+            # Read only
+            lines.append(f"{bubble} {vaddr}")
+
+    return lines
+
+
+def main():
+    parser = argparse.ArgumentParser(description="Generate synthetic Ramulator2 traces")
+    parser.add_argument("--num-accesses", type=int, default=100000, help="Number of memory accesses")
+    parser.add_argument("--num-pages", type=int, default=64, help="Number of unique pages (working set)")
+    parser.add_argument("--pattern", choices=["sequential", "random", "zipf", "strided"], default="random")
+    parser.add_argument("--bubble-mean", type=int, default=5, help="Mean bubble count between memory ops")
+    parser.add_argument("--page-size", type=int, default=4096, help="Page size in bytes")
+    parser.add_argument("--write-ratio", type=float, default=0.2, help="Fraction of writes")
+    parser.add_argument("--seed", type=int, default=42)
+    parser.add_argument("--output", type=str, required=True)
+    args = parser.parse_args()
+
+    lines = generate_trace(
+        args.num_accesses, args.num_pages, args.pattern,
+        args.bubble_mean, args.page_size, args.seed, args.write_ratio,
+    )
+
+    os.makedirs(os.path.dirname(args.output) or ".", exist_ok=True)
+    with open(args.output, "w") as f:
+        f.write("\n".join(lines) + "\n")
+
+    print(f"Generated {len(lines)} accesses, {args.num_pages} pages, pattern={args.pattern} → {args.output}")
+
+
+if __name__ == "__main__":
+    main()
