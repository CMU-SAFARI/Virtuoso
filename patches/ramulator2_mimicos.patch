diff --git a/src/translation/impl/mimicos_translation.cpp b/src/translation/impl/mimicos_translation.cpp
new file mode 100644
index 0000000..5a5074c
--- /dev/null
+++ b/src/translation/impl/mimicos_translation.cpp
@@ -0,0 +1,351 @@
+/**
+ * @file mimicos_translation.cpp
+ * @brief MimicOS-backed address translation for Ramulator2.
+ *
+ * Extends TLBTranslation by replacing the built-in page fault handler with
+ * IPC-based communication to a MimicOS process running under the SDE pintool.
+ *
+ * On page fault:
+ *   1. Send PAGE_FAULT_REQUEST to pintool (via pipe)
+ *   2. Receive MEMORY_ACCESS messages — inject into DRAM as PTW-like requests
+ *   3. Receive FAULT_RESPONSE — get PPN + PT frames from MimicOS allocator
+ *   4. Receive MIMICOS_DONE — fault handling complete
+ *   5. Install mapping and resume page table walk
+ *
+ * MimicOS is launched as a subprocess:
+ *   sde64 -t64 ramulator_recorder.so -ramulator:ipc_read_fd 3 -ramulator:ipc_write_fd 4
+ *     -- mimicos/build/startup_mimicos <config.ini> <trace.sift> <output>
+ */
+
+#include <cerrno>
+#include <cstdint>
+#include <cstring>
+#include <fcntl.h>
+#include <iostream>
+#include <signal.h>
+#include <string>
+#include <sys/wait.h>
+#include <unistd.h>
+#include <vector>
+
+#include "base/base.h"
+#include "base/request.h"
+#include "translation/translation.h"
+#include "frontend/frontend.h"
+#include "memory_system/memory_system.h"
+#include "frontend/impl/processor/simpleO3/llc.h"
+
+// Inline the IPC header
+namespace RamulatorIPC {
+  enum MsgType : uint8_t {
+    PAGE_FAULT_REQUEST = 1,
+    FAULT_RESPONSE = 2,
+    MEMORY_ACCESS = 3,
+    MIMICOS_READY = 4,
+    MIMICOS_DONE = 5,
+    SIMULATION_END = 10,
+  };
+  struct FaultRequest { uint64_t vpn; uint32_t num_frames_needed; uint32_t core_id; };
+  struct FaultResponse { uint64_t ppn; uint32_t page_size_log2; uint32_t num_frames; };
+  struct MemoryAccess { uint64_t addr; uint8_t is_write; };
+
+  static bool read_exact(int fd, void* buf, size_t len) {
+    size_t total = 0;
+    while (total < len) {
+      ssize_t n = read(fd, static_cast<char*>(buf) + total, len - total);
+      if (n <= 0) return false;
+      total += n;
+    }
+    return true;
+  }
+}
+
+namespace Ramulator {
+
+class MimicOSTranslation : public ITranslation, public Implementation {
+  RAMULATOR_REGISTER_IMPLEMENTATION(
+    ITranslation, MimicOSTranslation, "MimicOSTranslation",
+    "TLB translation with MimicOS userspace page fault handling via SDE pintool IPC."
+  );
+
+  // IPC state
+  pid_t m_mimicos_pid = -1;
+  int m_pipe_to_mimicos[2] = {-1, -1};    // Ramulator writes, pintool reads
+  int m_pipe_from_mimicos[2] = {-1, -1};  // Pintool writes, Ramulator reads
+  bool m_mimicos_ready = false;
+
+  // Config
+  std::string m_sde_path;
+  std::string m_pintool_path;
+  std::string m_mimicos_binary;
+  std::string m_mimicos_config;
+  std::string m_mimicos_trace;
+  std::string m_mimicos_output;
+
+  // Fault handling state
+  bool m_fault_in_progress = false;
+  bool m_fault_response_received = false;
+  RamulatorIPC::FaultResponse m_fault_response;
+  std::vector<uint64_t> m_fault_frames;
+
+  // Memory system for injecting MimicOS accesses
+  IMemorySystem* m_mem = nullptr;
+  void* m_llc_ptr = nullptr;
+  std::function<void(Request&)> m_frontend_callback;
+
+  // Stats
+  uint64_t s_mimicos_mem_accesses = 0;
+  uint64_t s_mimicos_faults_handled = 0;
+
+  // Delegate to an internal TLBTranslation for the actual TLB/PTW machinery
+  // (We'll create TLBTranslation as a child)
+  ITranslation* m_inner_translation = nullptr;
+
+public:
+  void init() override {
+    m_sde_path = param<std::string>("sde_path").desc("Path to sde64 binary").required();
+    m_pintool_path = param<std::string>("pintool_path").desc("Path to ramulator_recorder.so").required();
+    m_mimicos_binary = param<std::string>("mimicos_binary").desc("Path to MimicOS startup_mimicos").required();
+    m_mimicos_config = param<std::string>("mimicos_config").desc("Path to MimicOS .ini config").required();
+    m_mimicos_trace = param<std::string>("mimicos_trace").desc("Path to SIFT trace file").required();
+    m_mimicos_output = param<std::string>("mimicos_output").desc("MimicOS output prefix").default_val("/tmp/mimicos_ram_out");
+
+    // Create the inner TLBTranslation as a child for TLB/PTW machinery
+    m_inner_translation = create_child_ifce<ITranslation>();
+
+    // Wire up the fault handler so TLBTranslation calls us on page fault
+    m_inner_translation->set_fault_handler(
+      [this](uint64_t vpn, int num_frames, int core_id,
+             uint64_t& out_ppn, std::vector<uint64_t>& out_frames) -> bool {
+        return this->handle_page_fault_impl(vpn, num_frames, core_id, out_ppn, out_frames);
+      }
+    );
+
+    register_stat(s_mimicos_mem_accesses).name("mimicos_mem_accesses");
+    register_stat(s_mimicos_faults_handled).name("mimicos_faults_handled");
+
+    // Launch MimicOS subprocess
+    launch_mimicos();
+  }
+
+  void setup(IFrontEnd* frontend, IMemorySystem* memory_system) override {
+    m_mem = memory_system;
+  }
+
+  void set_cache(void* llc_ptr) override {
+    m_llc_ptr = llc_ptr;
+    if (m_inner_translation) m_inner_translation->set_cache(llc_ptr);
+  }
+
+  void set_receive_callback(std::function<void(Request&)> cb) override {
+    m_frontend_callback = cb;
+    if (m_inner_translation) m_inner_translation->set_receive_callback(cb);
+  }
+
+  void ptw_callback(Request& req) override {
+    if (m_inner_translation) m_inner_translation->ptw_callback(req);
+  }
+
+  bool translate(Request& req) override {
+    // Delegate to inner TLBTranslation
+    return m_inner_translation->translate(req);
+  }
+
+  Addr_t get_max_addr() override {
+    return m_inner_translation ? m_inner_translation->get_max_addr() : 0;
+  }
+
+  // Called by inner translation when a page fault occurs
+  // (TODO: hook into TLBTranslation's fault path)
+
+  ~MimicOSTranslation() {
+    // Signal pintool to exit
+    if (m_pipe_to_mimicos[1] >= 0) {
+      uint8_t end_msg = RamulatorIPC::SIMULATION_END;
+      write(m_pipe_to_mimicos[1], &end_msg, 1);
+      close(m_pipe_to_mimicos[1]);
+    }
+    if (m_pipe_from_mimicos[0] >= 0) close(m_pipe_from_mimicos[0]);
+
+    // Wait for MimicOS to exit
+    if (m_mimicos_pid > 0) {
+      int status;
+      waitpid(m_mimicos_pid, &status, WNOHANG);
+    }
+  }
+
+private:
+  void launch_mimicos() {
+    // Ignore SIGPIPE so write() to a broken pipe returns EPIPE instead of killing us
+    signal(SIGPIPE, SIG_IGN);
+
+    // Create pipes
+    if (pipe(m_pipe_to_mimicos) < 0 || pipe(m_pipe_from_mimicos) < 0) {
+      std::cerr << "[MimicOSTranslation] Failed to create pipes" << std::endl;
+      return;
+    }
+
+    m_mimicos_pid = fork();
+    if (m_mimicos_pid < 0) {
+      std::cerr << "[MimicOSTranslation] Failed to fork" << std::endl;
+      return;
+    }
+
+    if (m_mimicos_pid == 0) {
+      // Child: pass pipe FDs to the pintool via command-line args
+      // The pintool reads from pipe_to[0] and writes to pipe_from[1]
+      int read_fd = m_pipe_to_mimicos[0];
+      int write_fd = m_pipe_from_mimicos[1];
+
+      // Close unused ends
+      close(m_pipe_to_mimicos[1]);
+      close(m_pipe_from_mimicos[0]);
+
+      // Ensure the FDs we're passing survive exec
+      fcntl(read_fd, F_SETFD, 0);
+      fcntl(write_fd, F_SETFD, 0);
+
+      std::string ipc_read = std::to_string(read_fd);
+      std::string ipc_write = std::to_string(write_fd);
+
+      execlp(m_sde_path.c_str(), "sde64",
+             "-t64", m_pintool_path.c_str(),
+             "-ramulator:ipc_read_fd", ipc_read.c_str(),
+             "-ramulator:ipc_write_fd", ipc_write.c_str(),
+             "-ramulator:roi", "1",
+             "-ramulator:verbose", "1",
+             "--",
+             m_mimicos_binary.c_str(),
+             m_mimicos_config.c_str(),
+             m_mimicos_trace.c_str(),
+             m_mimicos_output.c_str(),
+             nullptr);
+
+      // If exec fails
+      std::cerr << "[MimicOSTranslation] execlp failed: " << strerror(errno) << std::endl;
+      _exit(1);
+    }
+
+    // Parent: close unused pipe ends
+    close(m_pipe_to_mimicos[0]);
+    close(m_pipe_from_mimicos[1]);
+
+    // Set read pipe to non-blocking for polling
+    int flags = fcntl(m_pipe_from_mimicos[0], F_GETFL, 0);
+    fcntl(m_pipe_from_mimicos[0], F_SETFL, flags | O_NONBLOCK);
+
+    std::cerr << "[MimicOSTranslation] MimicOS launched, pid=" << m_mimicos_pid << std::endl;
+
+    // Wait for MIMICOS_READY
+    // Switch to blocking briefly for init handshake
+    fcntl(m_pipe_from_mimicos[0], F_SETFL, flags);  // Restore blocking
+    uint8_t msg_type;
+    if (RamulatorIPC::read_exact(m_pipe_from_mimicos[0], &msg_type, 1) &&
+        msg_type == RamulatorIPC::MIMICOS_READY) {
+      char path[256];
+      // Read null-terminated path
+      for (int i = 0; i < 255; i++) {
+        if (read(m_pipe_from_mimicos[0], &path[i], 1) != 1 || path[i] == '\0') break;
+      }
+      m_mimicos_ready = true;
+      std::cerr << "[MimicOSTranslation] MimicOS ready" << std::endl;
+    }
+    // Back to non-blocking
+    fcntl(m_pipe_from_mimicos[0], F_SETFL, flags | O_NONBLOCK);
+  }
+
+  bool handle_page_fault_impl(uint64_t vpn, int num_frames, int core_id,
+                              uint64_t& out_ppn, std::vector<uint64_t>& out_frames) {
+    if (!m_mimicos_ready || m_pipe_to_mimicos[1] < 0) return false;
+
+    // Send fault request
+    RamulatorIPC::FaultRequest freq;
+    freq.vpn = vpn;
+    freq.num_frames_needed = num_frames;
+    freq.core_id = core_id;
+
+    uint8_t msg = RamulatorIPC::PAGE_FAULT_REQUEST;
+    write(m_pipe_to_mimicos[1], &msg, 1);
+    write(m_pipe_to_mimicos[1], &freq, sizeof(freq));
+
+    // Block until we get the response (this is during a stalled tick)
+    // Switch to blocking mode
+    int flags = fcntl(m_pipe_from_mimicos[0], F_GETFL, 0);
+    fcntl(m_pipe_from_mimicos[0], F_SETFL, flags & ~O_NONBLOCK);
+
+    bool done = false;
+    while (!done) {
+      uint8_t resp_type;
+      if (!RamulatorIPC::read_exact(m_pipe_from_mimicos[0], &resp_type, 1)) break;
+
+      switch (resp_type) {
+        case RamulatorIPC::MEMORY_ACCESS: {
+          RamulatorIPC::MemoryAccess ma;
+          RamulatorIPC::read_exact(m_pipe_from_mimicos[0], &ma, sizeof(ma));
+          s_mimicos_mem_accesses++;
+          // Inject MimicOS memory access into the DRAM system
+          inject_mimicos_access(ma);
+          break;
+        }
+
+        case RamulatorIPC::FAULT_RESPONSE: {
+          RamulatorIPC::read_exact(m_pipe_from_mimicos[0], &m_fault_response, sizeof(m_fault_response));
+          m_fault_frames.resize(m_fault_response.num_frames);
+          if (m_fault_response.num_frames > 0) {
+            RamulatorIPC::read_exact(m_pipe_from_mimicos[0],
+                                     m_fault_frames.data(),
+                                     m_fault_response.num_frames * sizeof(uint64_t));
+          }
+          m_fault_response_received = true;
+          break;
+        }
+
+        case RamulatorIPC::MIMICOS_DONE:
+          done = true;
+          s_mimicos_faults_handled++;
+          break;
+
+        default:
+          std::cerr << "[MimicOSTranslation] Unknown message type: " << (int)resp_type << std::endl;
+          done = true;
+          break;
+      }
+    }
+
+    // Restore non-blocking
+    fcntl(m_pipe_from_mimicos[0], F_SETFL, flags | O_NONBLOCK);
+
+    if (m_fault_response_received) {
+      out_ppn = m_fault_response.ppn;
+      out_frames = m_fault_frames;
+      m_fault_response_received = false;
+    }
+    return m_fault_response_received || out_ppn != 0;
+  }
+
+private:
+  void inject_mimicos_access(const RamulatorIPC::MemoryAccess& ma) {
+    if (!m_mem) return;
+
+    Addr_t addr = static_cast<Addr_t>(ma.addr);
+    Addr_t max_addr = m_inner_translation ? m_inner_translation->get_max_addr() : 0;
+    if (max_addr > 0) addr = addr % max_addr;
+
+    int type = ma.is_write ? Request::Type::Write : Request::Type::Read;
+    Request req(addr, type);
+    req.source_id = 0;
+    req.callback = m_frontend_callback;
+
+    // Send through LLC if available, otherwise directly to memory
+    bool sent = false;
+    if (m_llc_ptr) {
+      auto* llc = static_cast<SimpleO3LLC*>(m_llc_ptr);
+      sent = llc->send(req);
+    }
+    if (!sent && m_mem) {
+      m_mem->send(req);
+    }
+  }
+};
+
+}  // namespace Ramulator
