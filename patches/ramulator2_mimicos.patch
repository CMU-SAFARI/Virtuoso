--- /dev/null
+++ b/src/translation/impl/tlb_translation.cpp
@@ -0,0 +1,647 @@
+/**
+ * @file tlb_translation.cpp
+ * @brief Address translation with TLB hierarchy, page walk cache, PTW
+ *        through DRAM, and MSHR coalescing for Ramulator2.
+ *
+ * Latency model (all in frontend ticks):
+ *   L1 TLB hit:    l1_latency ticks (typically 1 — consumed by the tick that calls translate)
+ *   L1 miss → L2:  l1_miss_penalty ticks, then L2 lookup
+ *   L2 TLB hit:    l2_latency ticks
+ *   L2 miss → PTW: pwc_latency ticks for PWC lookup, then DRAM walk
+ *   PWC hit:        skip levels above hit level, continue walk from hit level - 1
+ *   PWC miss:       walk from level 4 (root)
+ *   Per-level PTW:  1 tick to issue + DRAM latency (real request through memory system)
+ *   Per-level PWC:  checked before each DRAM issue; if hit, skip that level (0 DRAM cost)
+ *
+ * Tick discipline:
+ *   - translate() called once per core::tick() for a stalled request
+ *   - DRAM callbacks only set flags; advance_walk() runs in translate()
+ *   - No reentrant m_mem->send() calls
+ */
+
+#include <cassert>
+#include <cstdint>
+#include <deque>
+#include <functional>
+#include <unordered_map>
+#include <unordered_set>
+#include <vector>
+
+#include "base/base.h"
+#include "base/request.h"
+#include "translation/translation.h"
+#include "frontend/frontend.h"
+#include "memory_system/memory_system.h"
+#include "frontend/impl/processor/simpleO3/llc.h"
+
+namespace Ramulator {
+
+// ============================================================================
+// TLB
+// ============================================================================
+class TLB {
+public:
+  struct Entry { Addr_t vpn = -1; Addr_t ppn = -1; bool valid = false; uint64_t stamp = 0; };
+
+  TLB(int entries, int assoc, int lat)
+    : m_nsets(entries / assoc), m_assoc(assoc), m_lat(lat) {
+    m_sets.resize(m_nsets, std::vector<Entry>(m_assoc));
+  }
+
+  std::pair<bool, Addr_t> lookup(Addr_t vpn) {
+    auto& s = m_sets[vpn % m_nsets];
+    for (auto& e : s) if (e.valid && e.vpn == vpn) { e.stamp = ++m_c; return {true, e.ppn}; }
+    return {false, -1};
+  }
+
+  void insert(Addr_t vpn, Addr_t ppn) {
+    auto& s = m_sets[vpn % m_nsets];
+    for (auto& e : s) if (!e.valid) { e = {vpn, ppn, true, ++m_c}; return; }
+    auto* v = &s[0]; for (auto& e : s) if (e.stamp < v->stamp) v = &e;
+    *v = {vpn, ppn, true, ++m_c};
+  }
+
+  int latency() const { return m_lat; }
+
+private:
+  int m_nsets, m_assoc, m_lat;
+  uint64_t m_c = 0;
+  std::vector<std::vector<Entry>> m_sets;
+};
+
+// ============================================================================
+// Page Walk Cache — per-level caches for intermediate PTEs
+// ============================================================================
+class PageWalkCache {
+public:
+  PageWalkCache(int cap_per_level, int lookup_lat)
+    : m_cap(cap_per_level), m_lat(lookup_lat) {}
+
+  // Check if we have a cached frame for this vpn at this level
+  // Returns frame_ppn on hit, -1 on miss
+  Addr_t lookup(Addr_t vpn, int level, int total_levels) {
+    if (level <= 1) return -1;  // Never cache leaf
+    Addr_t key = vpn >> (9 * (level - 1));
+    auto it = m_cache[level].find(key);
+    if (it != m_cache[level].end()) {
+      update_lru(level, key);
+      return it->second;
+    }
+    return -1;
+  }
+
+  // Find the deepest cached level (closest to leaf)
+  // Returns {hit_level, frame_ppn}, or {0, -1} if no hit
+  struct DeepResult { int level; Addr_t ppn; };
+  DeepResult lookup_deepest(Addr_t vpn, int total_levels) {
+    for (int lvl = 2; lvl <= total_levels; lvl++) {
+      Addr_t key = vpn >> (9 * (lvl - 1));
+      auto it = m_cache[lvl].find(key);
+      if (it != m_cache[lvl].end()) {
+        update_lru(lvl, key);
+        return {lvl, it->second};
+      }
+    }
+    return {0, -1};
+  }
+
+  void insert(Addr_t vpn, int level, int total_levels, Addr_t frame_ppn) {
+    if (level <= 1) return;
+    Addr_t key = vpn >> (9 * (level - 1));
+    auto& c = m_cache[level];
+    if (static_cast<int>(c.size()) >= m_cap) {
+      Addr_t lru = m_lru[level].back(); m_lru[level].pop_back(); c.erase(lru);
+    }
+    c[key] = frame_ppn;
+    m_lru[level].push_front(key);
+  }
+
+  int latency() const { return m_lat; }
+
+private:
+  int m_cap, m_lat;
+  std::unordered_map<int, std::unordered_map<Addr_t, Addr_t>> m_cache;
+  std::unordered_map<int, std::deque<Addr_t>> m_lru;
+
+  void update_lru(int level, Addr_t key) {
+    auto& q = m_lru[level];
+    q.erase(std::remove(q.begin(), q.end(), key), q.end());
+    q.push_front(key);
+  }
+};
+
+// ============================================================================
+// PageTable
+// ============================================================================
+class PageTable {
+public:
+  static constexpr int LEVELS = 4;
+  static constexpr int PAGE_OFFSET_BITS = 12;
+  struct Frame {
+    std::vector<Addr_t> entries;
+    Addr_t emulated_ppn;
+    Frame(Addr_t ppn) : entries(512, -1), emulated_ppn(ppn) {}
+  };
+
+  void set_allocator(std::function<Addr_t()> a) { m_alloc = a; }
+  void init() { m_frames.reserve(4096); m_frames.emplace_back(m_alloc()); }
+  int root() const { return 0; }
+
+  Addr_t pte_addr(int fi, Addr_t vpn, int lvl) const {
+    return m_frames[fi].emulated_ppn * 4096 + ((vpn >> (9*(lvl-1))) & 0x1FF) * 8;
+  }
+  Addr_t entry(int fi, Addr_t vpn, int lvl) const {
+    return m_frames[fi].entries[(vpn >> (9*(lvl-1))) & 0x1FF];
+  }
+  Addr_t frame_ppn(int fi) const { return m_frames[fi].emulated_ppn; }
+
+  void install(Addr_t vaddr, Addr_t ppn) {
+    Addr_t vpn = vaddr >> PAGE_OFFSET_BITS;
+    int fi = 0;
+    for (int l = LEVELS; l > 0; l--) {
+      int idx = (vpn >> (9*(l-1))) & 0x1FF;
+      if (l == 1) { m_frames[fi].entries[idx] = ppn; return; }
+      if (m_frames[fi].entries[idx] == -1) {
+        int ni = static_cast<int>(m_frames.size());
+        m_frames.emplace_back(m_alloc());
+        m_frames[fi].entries[idx] = ni;
+        fi = ni;
+      } else fi = static_cast<int>(m_frames[fi].entries[idx]);
+    }
+  }
+
+  // Walk to find the frame_idx at a given level for a vpn
+  int frame_at_level(Addr_t vpn, int target_level) const {
+    int fi = 0;
+    for (int l = LEVELS; l > target_level; l--) {
+      Addr_t e = m_frames[fi].entries[(vpn >> (9*(l-1))) & 0x1FF];
+      if (e == -1) return -1;
+      fi = static_cast<int>(e);
+    }
+    return fi;
+  }
+
+  // Check if mapping exists
+  bool has_mapping(Addr_t vpn) const {
+    int fi = 0;
+    for (int l = LEVELS; l > 0; l--) {
+      Addr_t e = m_frames[fi].entries[(vpn >> (9*(l-1))) & 0x1FF];
+      if (e == -1) return false;
+      if (l > 1) fi = static_cast<int>(e);
+    }
+    return true;
+  }
+
+private:
+  std::vector<Frame> m_frames;
+  std::function<Addr_t()> m_alloc;
+};
+
+// ============================================================================
+// Allocator
+// ============================================================================
+class Allocator {
+public:
+  Allocator(Addr_t kb, double) : m_n(1), m_m(kb*1024/4096) {}
+  Addr_t allocate() { if (m_n >= m_m) m_n = 1; return m_n++; }
+private:
+  Addr_t m_n; uint64_t m_m;
+};
+
+// ============================================================================
+// Walk state machine — explicit phases with tick counts
+// ============================================================================
+enum class WalkPhase {
+  PWC_LOOKUP,           // Checking PWC (costs pwc_latency ticks)
+  ISSUE_PTE_REQUEST,    // Ready to issue DRAM request for current level
+  WAIT_PTE_RESPONSE,    // Waiting for DRAM response
+  ADVANCE_LEVEL,        // DRAM responded, process and move to next level
+  COMPLETE,             // Walk finished, PPN available
+};
+
+struct WalkState {
+  Addr_t vpn;
+  int    core_id;
+  int    current_level;       // Current walk level (counting DOWN: 4→1)
+  int    frame_idx;           // Current page table frame index
+  Addr_t ppn = -1;
+  WalkPhase phase = WalkPhase::PWC_LOOKUP;
+  int    stall_remaining = 0; // Ticks to stall in current phase
+  bool   mem_response_received = false;
+  bool   complete = false;
+  std::vector<int> coalesced_cores;
+};
+
+// ============================================================================
+// Per-core translation state
+// ============================================================================
+enum class CorePhase {
+  IDLE,             // Not translating
+  L1_LOOKUP,        // L1 TLB lookup (consumes the calling tick)
+  L2_STALL,         // Waiting for L2 hit latency
+  WALKING,          // PTW in progress
+};
+
+struct CoreState {
+  CorePhase phase = CorePhase::IDLE;
+  int    stall = 0;
+  Addr_t vpn = -1;
+  Addr_t ppn = -1;
+};
+
+// ============================================================================
+// TLBTranslation
+// ============================================================================
+class TLBTranslation : public ITranslation, public Implementation {
+  RAMULATOR_REGISTER_IMPLEMENTATION(
+    ITranslation, TLBTranslation, "TLBTranslation",
+    "Full address translation: TLB, PWC, PTW through DRAM, MSHRs, cycle-accurate."
+  );
+
+  Addr_t m_max_addr;
+  int m_num_cores, m_pob = 12;
+
+  struct CTLBs { std::unique_ptr<TLB> l1d; std::unique_ptr<TLB> l1i; };
+  std::vector<CTLBs> m_l1;
+  std::unique_ptr<TLB> m_l2;
+
+  std::unique_ptr<PageWalkCache> m_pwc;
+  std::vector<std::unique_ptr<PageTable>> m_pts;
+  std::unique_ptr<Allocator> m_alloc;
+  IMemorySystem* m_mem = nullptr;
+  FaultHandler m_external_fault_handler;  // Optional: MimicOS handles faults
+
+  // LLC for PTW requests (PTEs go through cache hierarchy)
+  void* m_llc_ptr = nullptr;
+  // Frontend receive callback (same as core requests, for proper LLC dispatch)
+  std::function<void(Request&)> m_frontend_callback;
+
+  std::vector<CoreState> m_cs;
+  std::unordered_map<Addr_t, WalkState> m_walks;  // VPN → walk
+  std::vector<Addr_t> m_core_walk_vpn;  // Per-core: VPN being walked (-1 = none)
+
+  // Config
+  int m_l1_miss_penalty;
+  int m_num_walkers;  // Number of hardware page table walkers (= L2 TLB miss MSHRs)
+
+  uint64_t s_trans=0, s_l1h=0, s_l1m=0, s_l2h=0, s_l2m=0;
+  uint64_t s_walks=0, s_faults=0, s_ptw_dram=0;
+  uint64_t s_mshr=0, s_pwc_h=0, s_pwc_m=0, s_pwc_walk_h=0;
+  uint64_t s_walker_stalls=0;
+
+public:
+  void init() override {
+    m_max_addr       = param<Addr_t>("max_addr").required();
+    int l1d_sz       = param<int>("l1_dtlb_size").default_val(64);
+    int l1d_as       = param<int>("l1_dtlb_assoc").default_val(4);
+    int l1d_lat      = param<int>("l1_dtlb_latency").default_val(1);
+    int l1i_sz       = param<int>("l1_itlb_size").default_val(64);
+    int l1i_as       = param<int>("l1_itlb_assoc").default_val(4);
+    int l2_sz        = param<int>("l2_tlb_size").default_val(2048);
+    int l2_as        = param<int>("l2_tlb_assoc").default_val(8);
+    int l2_lat       = param<int>("l2_tlb_latency").default_val(8);
+    m_l1_miss_penalty = param<int>("l1_miss_penalty").default_val(1);
+    m_num_walkers    = param<int>("num_page_table_walkers").default_val(4);
+    int pwc_sz       = param<int>("pwc_entries_per_level").default_val(32);
+    int pwc_lat      = param<int>("pwc_latency").default_val(2);
+    Addr_t mem_kb    = param<Addr_t>("memory_size_kb").default_val(4LL*1024*1024);
+    double frag      = param<double>("target_fragmentation").default_val(0.0);
+
+    // Try to get num_cores from parent frontend; fall back to config param
+    int cfg_cores = param<int>("num_cores").default_val(0);
+    if (cfg_cores > 0) {
+      m_num_cores = cfg_cores;
+    } else {
+      m_num_cores = cast_parent<IFrontEnd>()->get_num_cores();
+    }
+
+    m_l1.resize(m_num_cores);
+    for (int c = 0; c < m_num_cores; c++) {
+      m_l1[c].l1d = std::make_unique<TLB>(l1d_sz, l1d_as, l1d_lat);
+      m_l1[c].l1i = std::make_unique<TLB>(l1i_sz, l1i_as, 1);
+    }
+    m_l2 = std::make_unique<TLB>(l2_sz, l2_as, l2_lat);
+    m_pwc = std::make_unique<PageWalkCache>(pwc_sz, pwc_lat);
+
+    m_alloc = std::make_unique<Allocator>(mem_kb, frag);
+    m_pts.resize(m_num_cores);
+    for (int c = 0; c < m_num_cores; c++) {
+      m_pts[c] = std::make_unique<PageTable>();
+      m_pts[c]->set_allocator([this]() { return m_alloc->allocate(); });
+      m_pts[c]->init();
+    }
+
+    m_cs.resize(m_num_cores);
+    m_core_walk_vpn.resize(m_num_cores, -1);
+
+    register_stat(s_trans).name("total_translations");
+    register_stat(s_l1h).name("l1_dtlb_hits");
+    register_stat(s_l1m).name("l1_dtlb_misses");
+    register_stat(s_l2h).name("l2_tlb_hits");
+    register_stat(s_l2m).name("l2_tlb_misses");
+    register_stat(s_walks).name("page_table_walks");
+    register_stat(s_faults).name("page_faults");
+    register_stat(s_ptw_dram).name("ptw_dram_accesses");
+    register_stat(s_mshr).name("ptw_mshr_merges");
+    register_stat(s_pwc_h).name("pwc_hits");
+    register_stat(s_pwc_m).name("pwc_misses");
+    register_stat(s_pwc_walk_h).name("pwc_walk_level_hits");
+    register_stat(s_walker_stalls).name("ptw_walker_stalls");
+  }
+
+  void setup(IFrontEnd* frontend, IMemorySystem* memory_system) override {
+    m_mem = memory_system;
+  }
+
+  void set_cache(void* llc_ptr) override {
+    m_llc_ptr = llc_ptr;
+  }
+
+  void set_fault_handler(FaultHandler handler) override {
+    m_external_fault_handler = handler;
+  }
+
+  void set_receive_callback(std::function<void(Request&)> cb) override {
+    m_frontend_callback = cb;
+  }
+
+  // Called by the frontend when a PTW request completes (hit or miss path)
+  void ptw_callback(Request& req) {
+    Addr_t vpn = static_cast<Addr_t>(req.scratchpad[1])
+               | (static_cast<Addr_t>(req.scratchpad[2]) << 31);
+    auto it = m_walks.find(vpn);
+    if (it != m_walks.end()) {
+      it->second.mem_response_received = true;
+    }
+  }
+
+  bool translate(Request& req) override {
+    int cid = req.source_id;
+    if (cid < 0 || cid >= m_num_cores) cid = 0;
+    Addr_t vaddr = req.addr;
+    Addr_t vpn = vaddr >> m_pob;
+    Addr_t off = vaddr & ((1ULL << m_pob) - 1);
+
+    s_trans++;
+    auto& cs = m_cs[cid];
+
+    // ── Handle ongoing stall (L2 hit latency or L1 miss penalty) ──
+    if (cs.phase == CorePhase::L2_STALL) {
+      cs.stall--;
+      if (cs.stall <= 0) {
+        cs.phase = CorePhase::IDLE;
+        m_l1[cid].l1d->insert(vpn, cs.ppn);
+        req.addr = pa(cs.ppn, off);
+        return true;
+      }
+      return false;
+    }
+
+    // ── Handle ongoing walk ──
+    if (cs.phase == CorePhase::WALKING) {
+      Addr_t w_vpn = m_core_walk_vpn[cid];
+      auto it = m_walks.find(w_vpn);
+      if (it != m_walks.end()) {
+        if (it->second.core_id == cid) advance_walk(it->second);
+        if (it->second.complete) return finish_walk(it->second, cid, req, vpn, off);
+        return false;
+      }
+      // Walk gone (completed by another core via MSHR)
+      cs.phase = CorePhase::IDLE;
+      m_core_walk_vpn[cid] = -1;
+      // Fall through — TLB should hit now
+    }
+
+    // ── L1 DTLB ──
+    auto [l1h, l1p] = m_l1[cid].l1d->lookup(vpn);
+    if (l1h) {
+      s_l1h++;
+      req.addr = pa(l1p, off);
+      return true;  // L1 hit: costs 1 tick (this tick)
+    }
+    s_l1m++;
+
+    // ── L2 TLB (after L1 miss) ──
+    auto [l2h, l2p] = m_l2->lookup(vpn);
+    if (l2h) {
+      s_l2h++;
+      int total_lat = m_l1_miss_penalty + m_l2->latency();
+      if (total_lat <= 1) {
+        m_l1[cid].l1d->insert(vpn, l2p);
+        req.addr = pa(l2p, off);
+        return true;
+      }
+      cs.phase = CorePhase::L2_STALL;
+      cs.stall = total_lat - 1;  // -1: this tick counts
+      cs.vpn = vpn;
+      cs.ppn = l2p;
+      return false;
+    }
+    s_l2m++;
+
+    // ── MSHR: coalesce with existing walk ──
+    auto wit = m_walks.find(vpn);
+    if (wit != m_walks.end()) {
+      // Coalescing doesn't consume a walker — it shares the existing one
+      wit->second.coalesced_cores.push_back(cid);
+      cs.phase = CorePhase::WALKING;
+      m_core_walk_vpn[cid] = vpn;
+      s_mshr++;
+      return false;
+    }
+
+    // ── Check walker availability (L2 TLB miss MSHRs) ──
+    if (static_cast<int>(m_walks.size()) >= m_num_walkers) {
+      // All page table walkers are busy — stall
+      s_walker_stalls++;
+      return false;
+    }
+
+    // ── Start new walk ──
+    s_walks++;
+    begin_walk(cid, vaddr, vpn);
+    cs.phase = CorePhase::WALKING;
+    m_core_walk_vpn[cid] = vpn;
+    return false;
+  }
+
+  Addr_t get_max_addr() override { return m_max_addr; }
+
+private:
+  Addr_t pa(Addr_t ppn, Addr_t off) {
+    return ((ppn << m_pob) | off) % m_max_addr;
+  }
+
+  void begin_walk(int cid, Addr_t vaddr, Addr_t vpn) {
+    auto& pt = *m_pts[cid];
+
+    // Resolve page fault if needed
+    if (!pt.has_mapping(vpn)) {
+      s_faults++;
+      if (m_external_fault_handler) {
+        // Use external handler (e.g., MimicOS)
+        uint64_t out_ppn = 0;
+        std::vector<uint64_t> out_frames;
+        m_external_fault_handler(vpn, PageTable::LEVELS - 1, cid, out_ppn, out_frames);
+        pt.install(vaddr, static_cast<Addr_t>(out_ppn));
+      } else {
+        // Built-in allocator (sniper-space style)
+        pt.install(vaddr, m_alloc->allocate());
+      }
+    }
+
+    WalkState ws;
+    ws.vpn = vpn;
+    ws.core_id = cid;
+    ws.current_level = PageTable::LEVELS;
+    ws.frame_idx = pt.root();
+    ws.phase = WalkPhase::PWC_LOOKUP;
+    ws.stall_remaining = m_pwc->latency();  // PWC lookup costs ticks
+
+    // Check PWC for deepest hit
+    auto pwc_r = m_pwc->lookup_deepest(vpn, PageTable::LEVELS);
+    if (pwc_r.level > 0) {
+      s_pwc_h++;
+      // Walk starts below the hit level
+      ws.current_level = pwc_r.level - 1;
+      int fi = pt.frame_at_level(vpn, ws.current_level);
+      if (fi >= 0) ws.frame_idx = fi;
+    } else {
+      s_pwc_m++;
+    }
+
+    // If after PWC we're already at leaf or below, complete immediately
+    if (ws.current_level <= 0) {
+      ws.ppn = pt.entry(ws.frame_idx, vpn, 1);
+      ws.phase = WalkPhase::COMPLETE;
+      ws.complete = true;
+    }
+
+    m_walks[vpn] = std::move(ws);
+  }
+
+  void advance_walk(WalkState& ws) {
+    if (ws.complete) return;
+    auto& pt = *m_pts[ws.core_id];
+
+    switch (ws.phase) {
+      case WalkPhase::PWC_LOOKUP:
+        // Stall for PWC lookup latency
+        if (ws.stall_remaining > 0) { ws.stall_remaining--; return; }
+        ws.phase = WalkPhase::ISSUE_PTE_REQUEST;
+        return;  // Will issue on the NEXT tick
+
+      case WalkPhase::ISSUE_PTE_REQUEST: {
+        // Before issuing DRAM, check PWC for this specific level
+        Addr_t pwc_ppn = m_pwc->lookup(ws.vpn, ws.current_level, PageTable::LEVELS);
+        if (pwc_ppn != -1) {
+          // PWC hit for this level — skip DRAM, advance immediately
+          s_pwc_walk_h++;
+          Addr_t entry_val = pt.entry(ws.frame_idx, ws.vpn, ws.current_level);
+          if (entry_val == -1) {
+            ws.complete = true; ws.ppn = 0; return;
+          }
+          if (ws.current_level == 1) {
+            ws.ppn = entry_val;
+            ws.phase = WalkPhase::COMPLETE;
+            ws.complete = true;
+            return;
+          }
+          m_pwc->insert(ws.vpn, ws.current_level, PageTable::LEVELS,
+                        pt.frame_ppn(static_cast<int>(entry_val)));
+          ws.frame_idx = static_cast<int>(entry_val);
+          ws.current_level--;
+          // Stay in ISSUE_PTE_REQUEST for next level (will check PWC again next tick)
+          return;
+        }
+
+        // No PWC hit — issue memory request through cache hierarchy
+        Addr_t pte_pa = pt.pte_addr(ws.frame_idx, ws.vpn, ws.current_level) % m_max_addr;
+        s_ptw_dram++;
+
+        Request pte_req(pte_pa, Request::Type::Read);
+        pte_req.source_id = ws.core_id;
+        pte_req.scratchpad[0] = 1;  // Mark as PTW request
+        pte_req.scratchpad[1] = static_cast<int>(ws.vpn & 0x7FFFFFFF);
+        pte_req.scratchpad[2] = static_cast<int>((ws.vpn >> 31) & 0x7FFFFFFF);
+        // Use the same callback as core data requests so the LLC
+        // miss→DRAM→receive() path works correctly
+        pte_req.callback = m_frontend_callback;
+
+        // Send through LLC (PTEs are cacheable and benefit from cache hierarchy)
+        bool sent = false;
+        if (m_llc_ptr) {
+          auto* llc = static_cast<SimpleO3LLC*>(m_llc_ptr);
+          sent = llc->send(pte_req);
+        } else if (m_mem) {
+          sent = m_mem->send(pte_req);
+        } else {
+          ws.mem_response_received = true;
+          ws.phase = WalkPhase::ADVANCE_LEVEL;
+          return;
+        }
+
+        if (sent) {
+          ws.phase = WalkPhase::WAIT_PTE_RESPONSE;
+        }
+        // If send fails (LLC/MSHR busy), stay in ISSUE and retry next tick
+        return;
+      }
+
+      case WalkPhase::WAIT_PTE_RESPONSE:
+        if (!ws.mem_response_received) return;  // Still waiting
+        ws.mem_response_received = false;
+        ws.phase = WalkPhase::ADVANCE_LEVEL;
+        return;  // Process on next tick
+
+      case WalkPhase::ADVANCE_LEVEL: {
+        Addr_t entry_val = pt.entry(ws.frame_idx, ws.vpn, ws.current_level);
+        if (entry_val == -1) {
+          ws.complete = true; ws.ppn = 0; return;
+        }
+
+        // Cache in PWC
+        if (ws.current_level > 1) {
+          m_pwc->insert(ws.vpn, ws.current_level, PageTable::LEVELS,
+                        pt.frame_ppn(static_cast<int>(entry_val)));
+        }
+
+        if (ws.current_level == 1) {
+          ws.ppn = entry_val;
+          ws.phase = WalkPhase::COMPLETE;
+          ws.complete = true;
+          return;
+        }
+
+        ws.frame_idx = static_cast<int>(entry_val);
+        ws.current_level--;
+        ws.phase = WalkPhase::ISSUE_PTE_REQUEST;  // Next level
+        return;
+      }
+
+      case WalkPhase::COMPLETE:
+        ws.complete = true;
+        return;
+    }
+  }
+
+  bool finish_walk(WalkState& ws, int cid, Request& req, Addr_t vpn, Addr_t off) {
+    Addr_t ppn = ws.ppn;
+    m_l1[ws.core_id].l1d->insert(vpn, ppn);
+    m_l2->insert(vpn, ppn);
+    m_cs[ws.core_id].phase = CorePhase::IDLE;
+    m_core_walk_vpn[ws.core_id] = -1;
+
+    for (int oc : ws.coalesced_cores) {
+      m_l1[oc].l1d->insert(vpn, ppn);
+      m_cs[oc].phase = CorePhase::IDLE;
+      m_core_walk_vpn[oc] = -1;
+    }
+
+    m_walks.erase(vpn);
+    req.addr = pa(ppn, off);
+    return true;
+  }
+};
+
+}  // namespace Ramulator
